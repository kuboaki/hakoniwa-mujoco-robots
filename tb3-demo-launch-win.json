{
  "version": "0.1",
  "defaults": {
    "cwd": ".",
    "stdout": "logs/${asset}.out",
    "stderr": "logs/${asset}.err",
    "env": {
      "prepend": {
        "lib_path": [
        ]
      }
    },    
    "start_grace_sec": 1,
    "delay_sec": 3
  },
  "assets": [
    {
      "name": "tb3_sim",
      "activation_timing": "before_start",
      "command": ".\\tb3_bin-win\\tb3_sim.exe ",
      "args": [
        "config/sensors/lidar/lds-01.json"
      ],
      "cwd": "."
    },
    {
      "name": "gamepad",
      "activation_timing": "after_start",
      "command": "python",
      "args": [
        "python/tb3_gamepad.py"
      ],
      "cwd": "."
    },
    {
      "name": "lidar",
      "activation_timing": "after_start",
      "command": "python",
      "args": [
        "python/tb3_lidar_visualizer.py"
      ],
      "cwd": "."
    }    
  ],
  "notify": {
    "type": "exec",
    "command": "scripts/notify_on_fail.sh",
    "args": ["${asset}", "asset_exit", "${timestamp}"]
  }
}