{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hakoniwa.dev/schemas/tf-output.schema.json",
  "title": "Hakoniwa TF output",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "spec",
        "mjcf_binding",
        "pdu_config"
      ],
      "properties": {
        "$schema": {
          "type": "string"
        },
        "spec": {
          "$ref": "#/$defs/spec"
        },
        "mjcf_binding": {
          "$ref": "#/$defs/mjcfBinding"
        },
        "pdu_config": {
          "$ref": "#/$defs/pduConfig"
        }
      }
    },
    {
      "allOf": [
        {
          "$ref": "./common-output.schema.json"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "transforms"
          ],
          "properties": {
            "$schema": {
              "type": "string"
            },
            "type": {
              "const": "tf"
            },
            "name": {
              "type": "string",
              "minLength": 1
            },
            "pdu_name": {
              "type": "string",
              "minLength": 1
            },
            "update_rate_hz": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "transforms": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/legacyTransform"
              }
            }
          }
        }
      ]
    }
  ],
  "$defs": {
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name",
        "transforms"
      ],
      "properties": {
        "type": {
          "const": "tf"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "transforms": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/specTransform"
          }
        }
      }
    },
    "specTransform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parent_frame_id",
        "child_frame_id"
      ],
      "properties": {
        "parent_frame_id": {
          "type": "string",
          "minLength": 1
        },
        "child_frame_id": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "legacyTransform": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "parent_frame_id",
        "child_frame_id",
        "source_body"
      ],
      "properties": {
        "parent_frame_id": {
          "type": "string",
          "minLength": 1
        },
        "child_frame_id": {
          "type": "string",
          "minLength": 1
        },
        "source_body": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "mjcfBinding": {
      "allOf": [
        {
          "$ref": "https://hakoniwa.dev/schemas/component-common.schema.json#/$defs/mjcfBindingBase"
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "transforms"
          ],
          "properties": {
            "config_style": {
              "const": "hakoniwa-sdf-like"
            },
            "runtime_source": {
              "const": "mjcf"
            },
            "transforms": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "child_frame_id",
                  "source_body"
                ],
                "properties": {
                  "child_frame_id": {
                    "type": "string",
                    "minLength": 1
                  },
                  "source_body": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        }
      ]
    },
    "pduConfig": {
      "allOf": [
        {
          "$ref": "https://hakoniwa.dev/schemas/component-common.schema.json#/$defs/requiredPduConfig"
        },
        {
          "type": "object",
          "properties": {
            "message_type": {
              "const": "tf2_msgs/TFMessage"
            }
          }
        }
      ]
    }
  }
}
