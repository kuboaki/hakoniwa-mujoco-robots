{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hakoniwa.dev/schemas/ultrasonic.schema.json",
  "title": "Hakoniwa Ultrasonic sensor profile",
  "description": "SDF-like but MJCF-resolved JSON config for ultrasonic range sensors used by Hakoniwa MuJoCo sensors.",
  "type": "object",
  "additionalProperties": false,
  "anyOf": [
    { "required": ["spec"] },
    {
      "required": [
        "frame_id",
        "RadiationType",
        "DetectionDistance",
        "DistanceAccuracy",
        "Cone",
        "UpdateRate"
      ]
    }
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "spec": {
      "$ref": "#/$defs/spec"
    },
    "frame_id": {
      "type": "string",
      "minLength": 1
    },
    "RadiationType": {
      "type": "string",
      "enum": ["ultrasound", "infrared"],
      "default": "ultrasound",
      "description": "Radiation type of the range sensor. Compatible with ROS sensor_msgs/Range: ultrasound=0, infrared=1."
    },    
    "DetectionDistance": {
      "$ref": "#/$defs/distanceRange"
    },
    "DistanceAccuracy": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/distanceAccuracy"
      }
    },
    "Cone": {
      "$ref": "#/$defs/cone"
    },
    "UpdateRate": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "RuntimeBinding": {
      "$ref": "#/$defs/mjcfBinding",
      "description": "Backward-compatible key for mjcf_binding."
    },
    "mjcf_binding": {
      "$ref": "#/$defs/mjcfBinding"
    },
    "pdu_config": {
      "$ref": "#/$defs/pduConfig"
    }
  },
  "$defs": {
    "spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frame_id",
        "RadiationType",
        "DetectionDistance",
        "DistanceAccuracy",
        "Cone",
        "UpdateRate"
      ],
      "properties": {
        "frame_id": {
          "type": "string",
          "minLength": 1
        },
        "RadiationType": {
          "type": "string",
          "enum": ["ultrasound", "infrared"],
          "default": "ultrasound",
          "description": "Radiation type of the range sensor. Compatible with ROS sensor_msgs/Range: ultrasound=0, infrared=1."
        },
        "DetectionDistance": {
          "$ref": "#/$defs/distanceRange"
        },
        "DistanceAccuracy": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/distanceAccuracy"
          }
        },
        "Cone": {
          "$ref": "#/$defs/cone"
        },
        "UpdateRate": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "distanceRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Min",
        "Max"
      ],
      "properties": {
        "Min": {
          "type": "number",
          "minimum": 0
        },
        "Max": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "distanceAccuracy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Range",
        "StdDev",
        "NoiseDistribution"
      ],
      "properties": {
        "Range": {
          "$ref": "#/$defs/distanceRange"
        },
        "StdDev": {
          "type": "number",
          "minimum": 0
        },
        "Precision": {
          "type": "number",
          "minimum": 0
        },
        "NoiseDistribution": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "cone": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "Horizontal",
        "Vertical",
        "RayCount"
      ],
      "properties": {
        "Horizontal": {
          "type": "number",
          "minimum": 0,
          "description": "Horizontal field of view in radians. Use 0 for a single center ray."
        },
        "Vertical": {
          "type": "number",
          "minimum": 0,
          "description": "Vertical field of view in radians. Use 0 for a single center ray."
        },
        "RayCount": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of rays used to approximate the ultrasonic cone."
        }
      }
    },
    "mjcfBinding": {
      "type": "object",
      "description": "Optional Hakoniwa MJCF binding fields for runtime resolution.",
      "additionalProperties": false,
      "properties": {
        "config_style": {
          "const": "hakoniwa-sdf-like"
        },
        "runtime_source": {
          "const": "mjcf"
        },
        "parent_body": {
          "type": "string",
          "minLength": 1
        },
        "source_body": {
          "type": "string",
          "minLength": 1
        },
        "source_site": {
          "type": "string",
          "minLength": 1
        },
        "frame_id_override": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "pduConfig": {
      "description": "Optional Hakoniwa PDU output settings.",
      "allOf": [
        {
          "$ref": "https://hakoniwa.dev/schemas/component-common.schema.json#/$defs/pduConfig"
        },
        {
          "properties": {
            "message_type": {
              "const": "sensor_msgs/Range"
            }
          }
        }
      ]
    }
  }
}
