{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hakoniwa.dev/schemas/multicamera.schema.json",
  "title": "Hakoniwa Multi-camera sensor profile",
  "description": "SDF-like but MJCF-resolved JSON config for multi-camera systems (e.g., stereo cameras).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "cameras"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "cameras": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "name",
          "pose",
          "camera_profile"
        ],
        "properties": {
          "name": {
            "type": "string",
            "description": "A unique name for this camera in the multi-camera system."
          },
          "pose": {
            "type": "object",
            "description": "Position and orientation relative to a base frame.",
            "properties": {
              "position": {
                "type": "object",
                "properties": {
                  "x": { "type": "number" },
                  "y": { "type": "number" },
                  "z": { "type": "number" }
                },
                "required": ["x", "y", "z"]
              },
              "orientation": {
                "type": "object",
                "properties": {
                  "roll": { "type": "number" },
                  "pitch": { "type": "number" },
                  "yaw": { "type": "number" }
                },
                "required": ["roll", "pitch", "yaw"]
              }
            }
          },
          "camera_profile": {
            "oneOf": [
              { "$ref": "camera.schema.json" },
              { "$ref": "rgbd-camera.schema.json" }
            ]
          }
        }
      }
    }
  },
  "$defs": {}
}
