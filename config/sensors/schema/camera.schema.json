{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hakoniwa.dev/schemas/camera.schema.json",
  "title": "Hakoniwa Camera sensor profile",
  "description": "SDF-like but MJCF-resolved JSON config for standard Camera profiles used by Hakoniwa MuJoCo sensors.",
  "type": "object",
  "additionalProperties": false,
  "oneOf": [
    {
      "required": [
        "frame_id",
        "update_rate",
        "image",
        "clip",
        "horizontal_fov"
      ]
    },
    {
      "required": [
        "spec"
      ]
    }
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "frame_id": {
      "type": "string",
      "minLength": 1
    },
    "update_rate": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "The frequency at which the sensor generates data, in Hz."
    },
    "horizontal_fov": {
      "type": "number",
      "exclusiveMinimum": 0,
      "maximum": 3.141592653589793,
      "description": "Horizontal field of view, in radians."
    },
    "image": {
      "$ref": "#/$defs/image"
    },
    "clip": {
      "$ref": "#/$defs/clip"
    },
    "noise": {
      "$ref": "#/$defs/noise"
    },
    "spec": {
      "$ref": "#/$defs/cameraSpec"
    },
    "mjcf_binding": {
      "$ref": "#/$defs/mjcfBinding"
    },
    "RuntimeBinding": {
      "$ref": "#/$defs/mjcfBinding",
      "description": "Backward-compatible key for mjcf_binding."
    },
    "pdu_config": {
      "$ref": "#/$defs/pduConfig"
    }
  },
  "$defs": {
    "cameraSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "frame_id",
        "update_rate",
        "image",
        "clip",
        "horizontal_fov"
      ],
      "properties": {
        "frame_id": {
          "type": "string",
          "minLength": 1
        },
        "update_rate": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "The frequency at which the sensor generates data, in Hz."
        },
        "horizontal_fov": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 3.141592653589793,
          "description": "Horizontal field of view, in radians."
        },
        "image": {
          "$ref": "#/$defs/image"
        },
        "clip": {
          "$ref": "#/$defs/clip"
        },
        "noise": {
          "$ref": "#/$defs/noise"
        }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "width",
        "height",
        "format"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        },
        "format": {
          "type": "string",
          "description": "Pixel format, e.g., 'R8G8B8', 'B8G8R8', 'L8'."
        }
      }
    },
    "clip": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "near",
        "far"
      ],
      "properties": {
        "near": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Near clipping distance in meters. Must be less than far."
        },
        "far": {
          "type": "number",
          "exclusiveMinimum": 0,
          "description": "Far clipping distance in meters. Must be greater than near."
        }
      }
    },
    "noise": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["none", "gaussian"],
          "description": "The type of noise model."
        },
        "mean": {
          "type": "number",
          "default": 0.0
        },
        "stddev": {
          "type": "number",
          "minimum": 0,
          "description": "The standard deviation of the noise distribution."
        }
      }
    },
    "mjcfBinding": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "config_style": {
          "const": "hakoniwa-sdf-like"
        },
        "runtime_source": {
          "const": "mjcf"
        },
        "camera_name": {
          "type": "string",
          "minLength": 1,
          "description": "MJCF camera name used by the camera renderer."
        },
        "body_name": {
          "type": "string",
          "minLength": 1,
          "description": "Optional MJCF body that owns or moves with the camera."
        },
        "freejoint_name": {
          "type": "string",
          "minLength": 1,
          "description": "Optional MJCF freejoint used by examples or tools to move the camera body."
        }
      }
    },
    "pduConfig": {
      "allOf": [
        {
          "$ref": "https://hakoniwa.dev/schemas/component-common.schema.json#/$defs/pduConfig"
        },
        {
          "properties": {
            "message_type": {
              "const": "sensor_msgs/Image"
            }
          }
        }
      ]
    }
  }
}
