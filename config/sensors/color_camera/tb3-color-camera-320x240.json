{
  "$schema": "../schema/camera.schema.json",
  "spec": {
    "frame_id": "color_camera_frame",
    "update_rate": 10,
    "horizontal_fov": 1.2,
    "image": {
      "width": 320,
      "height": 240,
      "format": "R8G8B8"
    },
    "clip": {
      "near": 0.05,
      "far": 10.0
    },
    "noise": {
      "type": "none",
      "mean": 0.0,
      "stddev": 0.0
    }
  },
  "mjcf_binding": {
    "config_style": "hakoniwa-sdf-like",
    "runtime_source": "mjcf",
    "camera_name": "color_camera",
    "body_name": "color_sensor_body"
  },
  "pdu_config": {
    "pdu_name": "camera_image",
    "update_rate_hz": 10,
    "message_type": "sensor_msgs/Image"
  }
}
