{
  "$schema": "../schema/lidar-2d.schema.json",
  "spec": {
    "type": "lidar_2d",
    "name": "lds_02",
    "frame_id": "laser",
    "DetectionDistance": {
      "Min": 160,
      "Max": 8000
    },
    "DistanceAccuracy": [
      {
        "Range": {
          "Min": 160,
          "Max": 300
        },
        "Type": "independent",
        "DistanceIndependentAccuracy": {
          "StdDev": 0.010,
          "NoiseDistribution": "Gaussian"
        }
      },
      {
        "Range": {
          "Min": 300,
          "Max": 6000
        },
        "Type": "dependent",
        "DistanceDependentAccuracy": {
          "Percentage": 3.0,
          "NoiseDistribution": "Gaussian"
        }
      },
      {
        "Range": {
          "Min": 6000,
          "Max": 8000
        },
        "Type": "dependent",
        "DistanceDependentAccuracy": {
          "Percentage": 5.0,
          "NoiseDistribution": "Gaussian"
        }
      }
    ],
    "AngleRange": {
      "Min": -180.0,
      "Max": 180.0,
      "AscendingOrderOfData": false,
      "Resolution": 1.0,
      "ScanFrequency": 5
    }
  },
  "mjcf_binding": {
    "config_style": "hakoniwa-sdf-like",
    "runtime_source": "mjcf",
    "parent_body": "base_link",
    "source_body": "base_scan",
    "exclude_body": "base_footprint"
  },
  "pdu_config": {
    "pdu_name": "laser_scan",
    "update_rate_hz": 5.0,
    "message_type": "sensor_msgs/LaserScan"
  }
}
